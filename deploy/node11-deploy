#!/usr/bin/env bash
set -euo pipefail

IMAGE=${1:-}
SERVICE=web_web
LOCK=/run/lock/socket23-deploy.lock

[[ "$IMAGE" =~ ^ghcr\.io/socket1923/site-infrastructure@sha256:[0-9a-f]{64}$ ]] || {
  echo "invalid image reference" >&2
  exit 64
}

exec 9>"$LOCK"
flock -n 9 || { echo "another deployment is active" >&2; exit 75; }

OLD_IMAGE=$(docker service inspect --format '{{.Spec.TaskTemplate.ContainerSpec.Image}}' "$SERVICE")
logger -t socket23-deploy "starting service=$SERVICE old=$OLD_IMAGE new=$IMAGE"

docker pull "$IMAGE"
if ! docker service update --detach=false --image "$IMAGE" --update-failure-action rollback "$SERVICE"; then
  logger -t socket23-deploy "service update failed; Docker rollback policy invoked"
  exit 1
fi

EXPECTED=$(docker service inspect --format '{{.Spec.Mode.Replicated.Replicas}}' "$SERVICE")
for _ in $(seq 1 60); do
  RUNNING=$(docker service ps --filter desired-state=running --format '{{.CurrentState}}' "$SERVICE" | grep -c '^Running' || true)
  if [[ "$RUNNING" -eq "$EXPECTED" ]]; then
    break
  fi
  sleep 2
done

RUNNING=$(docker service ps --filter desired-state=running --format '{{.CurrentState}}' "$SERVICE" | grep -c '^Running' || true)
if [[ "$RUNNING" -ne "$EXPECTED" ]] || ! curl --silent --show-error --fail --insecure     --resolve socket23.com:443:127.0.0.1 https://socket23.com/ | grep -q 'Socket23'; then
  logger -t socket23-deploy "post-deploy verification failed; rolling back to $OLD_IMAGE"
  docker service rollback --detach=false "$SERVICE" || true
  exit 1
fi

logger -t socket23-deploy "deployment verified service=$SERVICE image=$IMAGE replicas=$RUNNING"
printf 'deployment verified: service=%s image=%s replicas=%s\n' "$SERVICE" "$IMAGE" "$RUNNING"
