#!/usr/bin/env bash
set -euo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
TRACKING_IMAGE=ghcr.io/socket1923/site-infrastructure:latest
IMAGE_PREFIX=ghcr.io/socket1923/site-infrastructure@sha256:
SERVICE=web_web
EXPECTED_DELIVERY=immutable-pull-v1
LOCK=${XDG_RUNTIME_DIR:-/tmp}/socket23-pull-deploy.lock

exec 9>"$LOCK"
flock -n 9 || exit 0

DELIVERY=$(docker service inspect --format '{{index .Spec.Labels "com.socket23.delivery"}}' "$SERVICE")
if [[ "$DELIVERY" != "$EXPECTED_DELIVERY" ]]; then
  echo "service has not completed the immutable-stack migration" >&2
  exit 78
fi

docker pull --quiet "$TRACKING_IMAGE" >/dev/null
CANDIDATE=$(docker image inspect --format '{{range .RepoDigests}}{{println .}}{{end}}' "$TRACKING_IMAGE" \
  | grep -E "^${IMAGE_PREFIX}[0-9a-f]{64}$" \
  | head -n 1)
[[ "$CANDIDATE" =~ ^ghcr\.io/socket1923/site-infrastructure@sha256:[0-9a-f]{64}$ ]] || {
  echo "registry did not return an approved digest" >&2
  exit 65
}

CURRENT=$(docker service inspect --format '{{.Spec.TaskTemplate.ContainerSpec.Image}}' "$SERVICE")
if [[ "$CURRENT" == "$CANDIDATE" ]]; then
  exit 0
fi

logger -t socket23-deploy "starting service=$SERVICE old=$CURRENT new=$CANDIDATE"
if ! docker service update \
    --detach=false \
    --image "$CANDIDATE" \
    --update-order start-first \
    --update-failure-action rollback \
    "$SERVICE"; then
  logger -t socket23-deploy "service update failed; rollback policy invoked"
  exit 1
fi

EXPECTED=$(docker service inspect --format '{{.Spec.Mode.Replicated.Replicas}}' "$SERVICE")
for _ in $(seq 1 60); do
  RUNNING=$(docker service ps --filter desired-state=running --format '{{.CurrentState}}' "$SERVICE" \
    | grep -c '^Running' || true)
  if [[ "$RUNNING" -eq "$EXPECTED" ]]; then
    break
  fi
  sleep 2
done

RUNNING=$(docker service ps --filter desired-state=running --format '{{.CurrentState}}' "$SERVICE" \
  | grep -c '^Running' || true)
if [[ "$RUNNING" -ne "$EXPECTED" ]] || ! curl --silent --show-error --fail --insecure \
    --resolve socket23.com:443:127.0.0.1 \
    https://socket23.com/ | grep -q 'Socket23'; then
  logger -t socket23-deploy "verification failed; rolling back to $CURRENT"
  docker service rollback --detach=false "$SERVICE" || true
  exit 1
fi

logger -t socket23-deploy "verified service=$SERVICE image=$CANDIDATE replicas=$RUNNING"
printf 'deployment verified: service=%s image=%s replicas=%s\n' "$SERVICE" "$CANDIDATE" "$RUNNING"
