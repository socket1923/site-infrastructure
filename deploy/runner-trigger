#!/usr/bin/env bash
set -euo pipefail

IMAGE=${1:-}
[[ "$IMAGE" =~ ^ghcr\.io/socket1923/site-infrastructure@sha256:[0-9a-f]{64}$ ]] || {
  echo "invalid image reference" >&2
  exit 64
}

exec ssh \
  -o BatchMode=yes \
  -o IdentitiesOnly=yes \
  -o StrictHostKeyChecking=yes \
  -o ClearAllForwardings=yes \
  node11-deploy "deploy $IMAGE"
